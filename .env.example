# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: n8n / automation webhook (POST JSON on new lead)
N8N_WEBHOOK_URL=

# Optional: Google Maps (map picker on quote form)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Site URL for magic links (production: https://your-domain.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# /projects gallery — feed images without Facebook API (recommended for Vercel)
# JSON array: [{"src":"https://example.com/p5.jpg","title":"Project 5","caption":"optional"}]
# NEXT_PUBLIC_PROJECT_GALLERY_JSON=
# Or comma-separated URLs (titles become Project 1, Project 2, …)
# NEXT_PUBLIC_PROJECT_IMAGE_URLS=https://...,https://...

# Optional: Facebook Graph API (advanced; not required for static image feed)
NEXT_PUBLIC_FACEBOOK_PAGE_ID=100064946531847
FACEBOOK_PAGE_ACCESS_TOKEN=
NEXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/profile.php?id=100064946531847
